{
  "name": "vault-gta",
  "version": "10.30.0",
  "description": "VaultGTA - GTA Online Vehicle Collection Tracker",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "VaultGTA",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "dexie": "^4.0.8",
    "electron-updater": "^6.8.9",
    "html2canvas": "^1.4.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.vaultgta.tracker",
    "productName": "VaultGTA",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "sw.js",
      "package.json",
      "src/**/*",
      "vendor/**/*",
      "vehicles.json",
      "xhh_slugs.json",
      "liveries.json",
      "gta-colors.json",
      "street-car-colors.json",
      "wiki-colors.json",
      "vehicle-blacklist.json",
      "vehicle-parts-restrictions.json",
      "street-car-models.json",
      "assets/liveries.pdf",
      "assets/**/*",
      "garage-scanner-overlay.html",
      "license-plate-creator.html",
      "reset-password.html",
      "magic-link.html",
      "installer/setup.html",
      "installer/setup-preload.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/app-icon.png"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerSidebar": "build/installerSidebar.bmp",
      "shortcutName": "VaultGTA",
      "include": "build/installer.nsh"
    }
  }
}
